{
  "name": "@univerkit/verso",
  "version": "1.0.0-rc.0",
  "description": "A focused release CLI for JavaScript workspace packages.",
  "license": "MIT",
  "author": "DreamNum Co., Ltd. <developer@univer.ai>",
  "homepage": "https://github.com/dream-num/verso#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dream-num/verso.git",
    "directory": "packages/verso"
  },
  "bugs": {
    "url": "https://github.com/dream-num/verso/issues"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "keywords": [
    "release",
    "changelog",
    "semver",
    "workspace",
    "monorepo",
    "cli"
  ],
  "type": "module",
  "bin": {
    "verso": "bin/verso.js"
  },
  "files": [
    "bin",
    "dist",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/rewrite-dist-imports.mts && node scripts/build-bin.mts",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build"
  },
  "optionalDependencies": {
    "@univerkit/verso-darwin-arm64": "workspace:*",
    "@univerkit/verso-darwin-x64": "workspace:*",
    "@univerkit/verso-linux-arm64": "workspace:*",
    "@univerkit/verso-linux-x64": "workspace:*",
    "@univerkit/verso-win32-x64": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
